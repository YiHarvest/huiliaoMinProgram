<view class="page">
  <scroll-view scroll-y class="page-scroll">
    <view class="hero-shell">
      <swiper
        class="hero-swiper"
        autoplay="{{true}}"
        circular="{{true}}"
        interval="4200"
        duration="520"
        current="{{currentBanner}}"
        bindchange="onSwiperChange"
      >
        <swiper-item wx:for="{{bannerList}}" wx:key="id">
          <view class="hero-slide">
            <view class="hero-image-wrap">
              <image class="hero-image" src="{{item.image}}" mode="aspectFill" />
            </view>
            <view class="hero-overlay"></view>

            <view class="hero-content">
              <text class="hero-kicker">{{item.kicker}}</text>
              <text class="hero-title">{{item.title}}</text>
              <text class="hero-subtitle">{{item.subtitle}}</text>
              <view class="hero-chip-row">
                <text class="hero-chip" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>

      <view class="hero-indicators">
        <view
          class="hero-indicator {{currentBanner === index ? 'hero-indicator-active' : ''}}"
          wx:for="{{bannerList}}"
          wx:key="id"
        ></view>
      </view>
    </view>

    <view class="section feature-section">
      <view class="section-header">
        <text class="section-title">核心功能</text>
      </view>

      <view class="feature-grid">
        <view class="feature-card" wx:for="{{featureGrid}}" wx:key="title">
          <view class="feature-icon-wrap">
            <view class="feature-icon-halo"></view>
            <view class="feature-icon-core">
              <view wx:if="{{item.iconType === 'ai'}}" class="icon-ai">
                <view class="icon-ai-node icon-ai-node-a"></view>
                <view class="icon-ai-node icon-ai-node-b"></view>
                <view class="icon-ai-node icon-ai-node-c"></view>
                <view class="icon-ai-center"></view>
                <view class="icon-ai-line icon-ai-line-a"></view>
                <view class="icon-ai-line icon-ai-line-b"></view>
                <view class="icon-ai-line icon-ai-line-c"></view>
              </view>

              <view wx:elif="{{item.iconType === 'monitor'}}" class="icon-monitor">
                <view class="icon-monitor-frame"></view>
                <view class="icon-monitor-wave"></view>
                <view class="icon-monitor-dot"></view>
              </view>

              <view wx:elif="{{item.iconType === 'pill'}}" class="icon-pill">
                <view class="icon-pill-shell"></view>
                <view class="icon-pill-cut"></view>
                <view class="icon-pill-dot"></view>
              </view>

              <view wx:elif="{{item.iconType === 'chart'}}" class="icon-chart">
                <view class="icon-chart-bar icon-chart-bar-a"></view>
                <view class="icon-chart-bar icon-chart-bar-b"></view>
                <view class="icon-chart-bar icon-chart-bar-c"></view>
                <view class="icon-chart-line"></view>
              </view>
            </view>
          </view>

          <text class="feature-title">{{item.title}}</text>
          <text class="feature-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="section compact-section">
      <view class="section-header">
        <text class="section-title">榕慧模式</text>
        <text class="section-subtitle">嵌入医院体系，沉淀患者关系，形成长期服务能力</text>
      </view>

      <view class="journey-card">
        <view class="journey-step" wx:for="{{journeySteps}}" wx:key="title">
          <view class="journey-index">{{index + 1}}</view>
          <view class="journey-body">
            <text class="journey-title">{{item.title}}</text>
            <text class="journey-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="cta-card">
      <text class="cta-title">了解更多解决方案</text>
      <text class="cta-desc">查看榕慧模式、专家网络与公司介绍。</text>
      <view class="cta-actions">
        <view class="cta-btn cta-btn-primary" bindtap="onLearnMoreTap">了解方案</view>
        <view class="cta-btn cta-btn-secondary" bindtap="onAboutTap">关于我们</view>
      </view>
    </view>
  </scroll-view>
</view>
