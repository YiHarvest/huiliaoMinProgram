<view class="message-settings">
  <view class="header">
    <text class="title">消息提醒设置</text>
    <text class="subtitle">管理您的订阅消息通知</text>
  </view>

  <view class="guide-card" wx:if="{{configured}}">
    <view class="guide-icon">ℹ️</view>
    <view class="guide-content">
      <text class="guide-title">关于消息订阅</text>
      <text class="guide-text">开启订阅后，您将及时收到AI回复、舌诊结果和预约提醒等服务通知</text>
    </view>
    <view class="guide-action" bindtap="onShowGuide">
      <text class="guide-link">查看详情</text>
    </view>
  </view>

  <view class="config-warning" wx:if="{{!configured && !isLoading}}">
    <text class="warning-icon">⚠️</text>
    <text class="warning-text">消息订阅功能尚未配置，请联系管理员</text>
  </view>

  <view class="subscription-list" wx:if="{{configured && !isLoading}}">
    <view class="list-header">
      <text class="list-title">订阅消息类型</text>
    </view>

    <view class="subscription-item" wx:for="{{subscriptions}}" wx:key="scene">
      <view class="item-info">
        <view class="item-header">
          <text class="item-name">{{item.name}}</text>
          <view class="item-status" wx:if="{{item.subscribed}}">
            <text class="status-text">已订阅</text>
          </view>
        </view>
        <text class="item-description">{{item.description}}</text>
      </view>
      <view class="item-action" wx:if="{{item.enabled && !item.subscribed}}" 
            data-scene="{{item.scene}}" 
            bindtap="onSubscribeScene">
        <text class="action-text">订阅</text>
      </view>
      <view class="item-action disabled" wx:elif="{{!item.enabled}}">
        <text class="action-text">暂不可用</text>
      </view>
      <view class="item-action subscribed" wx:else>
        <text class="action-text">已开启</text>
      </view>
    </view>
  </view>

  <view class="actions" wx:if="{{configured && !isLoading}}">
    <button class="subscribe-all-btn" 
            bindtap="onSubscribeAll"
            disabled="{{!canSubscribeAny}}">
      <text>一键开启所有提醒</text>
    </button>
  </view>

  <view class="settings-section" wx:if="{{!isLoading}}">
    <view class="settings-item" bindtap="onOpenSettings">
      <view class="settings-info">
        <text class="settings-title">系统设置</text>
        <text class="settings-desc">管理小程序的系统权限</text>
      </view>
      <view class="settings-arrow">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>