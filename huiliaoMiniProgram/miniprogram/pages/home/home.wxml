<view class="page">
  <scroll-view scroll-y class="page-scroll">
    <view class="hero-shell">
      <swiper
        class="hero-swiper"
        autoplay="{{true}}"
        circular="{{true}}"
        interval="4200"
        duration="520"
        current="{{currentBanner}}"
        bindchange="onSwiperChange"
      >
        <swiper-item wx:for="{{bannerList}}" wx:key="id">
          <view class="hero-slide">
            <view class="hero-image-wrap">
              <image class="hero-image" src="{{item.image}}" mode="aspectFill" />
            </view>
            <view class="hero-overlay"></view>

            <view class="hero-content">
              <view class="hero-info-area">
                <text class="hero-pill-label">患者管理</text>
                <text class="hero-main-title">全周期服务更高效</text>
                <text class="hero-short-desc">从诊前到诊后，持续连接患者</text>
                <view class="hero-function-tags">
                  <text class="hero-function-tag">患者连接</text>
                  <text class="hero-function-tag">持续服务</text>
                </view>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>

      <view class="hero-indicators">
        <view
          class="hero-indicator {{currentBanner === index ? 'hero-indicator-active' : ''}}"
          wx:for="{{bannerList}}"
          wx:key="id"
        ></view>
      </view>
    </view>

    <view class="section feature-section">
      <view class="section-header">
        <text class="section-title">核心功能</text>
      </view>

      <view class="feature-grid">
        <view
          class="feature-card"
          wx:for="{{featureGrid}}"
          wx:key="title"
          data-route="{{item.route}}"
          data-title="{{item.title}}"
          bindtap="onOpenFeature"
          hover-class="feature-card-hover"
          hover-stay-time="80"
        >
          <view class="feature-icon-wrap">
            <view class="feature-icon-halo"></view>
            <view class="feature-icon-core">
              <view wx:if="{{item.iconType === 'clipboard'}}" class="icon-clipboard">
                <text class="icon-emoji">📋</text>
              </view>

              <view wx:elif="{{item.iconType === 'tongue'}}" class="icon-tongue">
                <text class="icon-emoji">👅</text>
              </view>

              <view wx:elif="{{item.iconType === 'report'}}" class="icon-report">
                <text class="icon-emoji">📄</text>
              </view>

              <view wx:elif="{{item.iconType === 'profile'}}" class="icon-profile">
                <text class="icon-emoji">👤</text>
              </view>
            </view>
          </view>

          <text class="feature-title">{{item.title}}</text>
          <text class="feature-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 功能介绍 -->
    <view class="section intro-section">
      <view class="intro-content">
        <text class="intro-title">功能介绍：</text>
        <view class="intro-list">
          <view class="intro-item">
            <view class="intro-number">1</view>
            <view class="intro-text">填写量表——分析专病问题</view>
          </view>
          <view class="intro-item">
            <view class="intro-number">2</view>
            <view class="intro-text">上传舌苔——辨识中医体质</view>
          </view>
          <view class="intro-item">
            <view class="intro-number">3</view>
            <view class="intro-text">上传报告——识别生理指标</view>
          </view>
          <view class="intro-item">
            <view class="intro-number">4</view>
            <view class="intro-text">整合各项数据——生成专属全面的健康画像。AI医生智能体会为您定制个性化调理与治疗方案，高效守护您的健康。</view>
          </view>
        </view>
      </view>
    </view>

