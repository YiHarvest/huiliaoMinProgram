<scroll-view class="page-scroll" scroll-y enable-flex="true">
  <view class="page">
    <view class="section-card">
      <view class="section-head">
        <text class="section-title">常见问题</text>
        <text class="section-note">使用帮助</text>
      </view>

      <view class="faq-list">
        <view 
          class="faq-item" 
          wx:for="{{faqList}}" 
          wx:key="index"
          bindtap="toggleFaq"
          data-index="{{index}}"
        >
          <view class="faq-header">
            <text class="faq-question">{{item.question}}</text>
            <view class="faq-arrow {{item.expanded ? 'faq-arrow-expanded' : ''}}">
              <text class="arrow-icon">›</text>
            </view>
          </view>
          <view class="faq-content {{item.expanded ? 'faq-content-expanded' : ''}}">
            <text class="faq-answer">{{item.answer}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="footer">
      <text class="footer-text">如有其他问题，请联系客服</text>
    </view>
  </view>
</scroll-view>
