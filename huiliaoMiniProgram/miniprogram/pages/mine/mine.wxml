<scroll-view class="page-scroll" scroll-y enable-flex="true">
  <view class="page">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-card-bg"></view>
      <view class="user-card-glow"></view>
      
      <view class="user-content">
        <view class="user-left">
          <view class="avatar-wrap">
            <image 
              class="avatar" 
              src="{{profile.avatarUrl || '/assets/icons/mine.png'}}" 
              mode="aspectFill"
            ></image>
            <view class="avatar-badge">
              <text class="badge-text">+</text>
            </view>
          </view>
          
          <view class="user-detail">
            <text class="user-name">{{profile.nickname || '用户昵称'}}</text>
            <text class="user-id">ID: {{profile.userId || 'test_user_id'}}</text>
          </view>
        </view>
        
        <view class="edit-btn" bindtap="onEditProfile">
          <text class="edit-icon">✏️</text>
          <text class="edit-text">完善资料</text>
        </view>
      </view>
      
      <view class="user-status">
        <text class="status-text">健康档案 · 已完善基础资料</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-group">
        <view 
          class="menu-item" 
          bindtap="onNavigateToPersonalData"
          hover-class="menu-item-hover"
          hover-stay-time="80"
        >
          <view class="menu-icon menu-icon-data">
            <text class="menu-icon-text">📊</text>
          </view>
          <view class="menu-content">
            <text class="menu-label">我的数据</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>

        <view 
          class="menu-item" 
          bindtap="onContactUs"
          hover-class="menu-item-hover"
          hover-stay-time="80"
        >
          <view class="menu-icon menu-icon-contact">
            <text class="menu-icon-text">💬</text>
          </view>
          <view class="menu-content">
            <text class="menu-label">联系我们</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>

        <view 
          class="menu-item" 
          bindtap="onFAQ"
          hover-class="menu-item-hover"
          hover-stay-time="80"
        >
          <view class="menu-icon menu-icon-faq">
            <text class="menu-icon-text">❓</text>
          </view>
          <view class="menu-content">
            <text class="menu-label">常见问题</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>

        <view 
          class="menu-item" 
          bindtap="onPrivacyPolicy"
          hover-class="menu-item-hover"
          hover-stay-time="80"
        >
          <view class="menu-icon menu-icon-privacy">
            <text class="menu-icon-text">🔒</text>
          </view>
          <view class="menu-content">
            <text class="menu-label">隐私政策</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>

        <view 
          class="menu-item" 
          bindtap="onUserAgreement"
          hover-class="menu-item-hover"
          hover-stay-time="80"
        >
          <view class="menu-icon menu-icon-agreement">
            <text class="menu-icon-text">📄</text>
          </view>
          <view class="menu-content">
            <text class="menu-label">用户协议</text>
          </view>
          <view class="menu-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="version-info">
      <text class="version-text">v1.2.0</text>
      <text class="copyright">银川慧疗互联网医院</text>
    </view>
  </view>
</scroll-view>
